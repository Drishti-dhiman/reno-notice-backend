{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "types": ["node"],
    "skipLibCheck": true,
    "noEmitOnError": true
    // "sourceMap": true
  },

  // "include": ["src/**/*.ts", "generated/**/*.ts"],
    "exclude": ["node_modules", "dist", "generated", "**/generated/**"]
}
