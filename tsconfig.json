{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "types": ["node"],
    "skipLibCheck": true,
    "noEmitOnError": true
    // "sourceMap": true
  },

  "include": ["src/**/*.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "dist", "src/controllers/notice.controller.ts", "src/routes/notice.routes.ts", "src/lib/validateNotic.ts"]
}
