generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Notice {
  id          Int            @id @default(autoincrement())
  title       String
  body        String
  category    NoticeCategory @default(GENERAL)
  priority    NoticePriority @default(NORMAL)
  publishDate DateTime
  imageUrl    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime

  @@index([priority, publishDate])
}

enum NoticeCategory {
  EXAM
  EVENT
  GENERAL
}

enum NoticePriority {
  NORMAL
  URGENT
}
